# IFT Website – Supabase (Auth + CMS)
# Copy to .env and fill with your Supabase project values.
# See DEPLOY.md for setup instructions.

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key-here

# Password gate: when both set, shows a single password prompt instead of Login form.
# User enters password; if valid, signInWithPassword(EMAIL, PASSWORD) is called.
# Do not commit .env with real credentials.
VITE_GATE_PASSWORD=
VITE_ADMIN_EMAIL=admin@example.com
