# IFT Website – Local CMS (no database)
# Copy to .env and adjust as needed.
# CMS content: localStorage (fallback) or API when VITE_API_URL is set.

# Password gate: when both set, shows a single password prompt for edit access.
# User enters password; if it matches, they get admin edit rights for this session.
# Do not commit .env with real credentials.
VITE_GATE_PASSWORD=
VITE_ADMIN_EMAIL=admin@example.com

# Backend API: when set, frontend uses resource API instead of localStorage.
# Dev with Vite proxy (avoids CORS): leave empty or set VITE_API_URL=/api
# Direct backend: VITE_API_URL=http://localhost:8000
VITE_API_URL=
