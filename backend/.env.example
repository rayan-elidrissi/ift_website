# IFT CMS Backend – Copy to .env
# File-based storage. No external database.

# Database paths (relative to backend dir)
DB_PATH=./db
DB_UPLOAD_BASE_PATH=./uploads

# JWT signing (change in production)
JWT_SECRET=dev-secret-change-in-production

# CORS (frontend URL)
CORS_ORIGINS=http://localhost:3000

# Frontend URL (for OAuth redirects)
FRONTEND_URL=http://localhost:3000

# OAuth (optional – Google, GitHub, Auth0, etc.)
# When not set, /login redirects to frontend.
OAUTH_AUTH_URL=
OAUTH_TOKEN_URL=
OAUTH_USERINFO_URL=
OAUTH_CLIENT_ID=
OAUTH_CLIENT_SECRET=
OAUTH_REDIRECT_URI=
OAUTH_SCOPES=openid email profile
